# ============================================================
# Infinite-Canvas .gitignore
# ============================================================

# ---------- 运行时数据目录（用户数据，不应提交） ----------
data/
API/
assets/
output/
history.json
global_config.json

# ---------- 环境变量配置文件（敏感信息，不应提交） ----------
.env

# ---------- Python 相关 ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
tmp/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ---------- 便携 Python 运行时和离线包 ----------
python/
packages/
get-pip.py

# ---------- Docker 打包导出 ----------
deploy/
dist/
*.tar
*.tar.gz
*.zip

# ---------- IDE / 编辑器 ----------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ---------- 操作系统文件 ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- 日志文件 ----------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- 本地配置文件 ----------
*.local
.env
.env.local
.env.*.local

# ---------- 测试覆盖率 ----------
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ---------- 临时文件 ----------
*.tmp
*.temp
*.bak
*.old
